#!/bin/bash

# Ensure envs directory exists
mkdir -p envs

# Check if any env files exist, if not create default
NUM=$(ls -1 envs | wc -l)
if [[ $NUM -eq 0 ]]; then
    PROJECT_FOLDER=$(basename "$(dirname "$(pwd)")")
    CPU=$(uname -m)
    
    cat > envs/default <<EOF
CPU=${CPU}
#DEFAULT=random
#SERVICES="ssh"
PROJECT=${PROJECT_FOLDER}
APP_URL=http://127.0.0.1:1050
FOLDER=..
HTTP_PORT=1050
#HTTPS_PORT=1150
#DB_PORT=1250
#SSH_PORT=2222
#DRIVE_PORT=2223
USER_ID=$(id -u)
GROUP_ID=$(id -g)
EOF
    echo "Default environment template created in envs/default."
    echo "You can now edit it and run ./link again."
    ln -sf envs/default .env
    exit 0
fi

# Quick link if argument provided
if [[ -n "$1" ]]; then
    if [[ ! -f "envs/$1" ]]; then
        echo "Error: envs/$1 not found."
        exit 1
    fi
    ln -sf "envs/$1" .env
    echo "Linked .env to $(readlink .env)"
    ./info
    exit 0
fi

# Interactive selection
echo "Select a project environment:"
array=($(cd envs && ls | grep -v '^@' | sort))
touch authorized_keys

PS3="Enter number: "
select option in "${array[@]}"; do
    if [[ -n "$option" ]]; then
        ln -sf "envs/$option" .env
        echo ".env linked to envs/$option"
        source .env
        if [[ ! -d "$FOLDER" ]]; then
            echo "Warning: Project folder '$FOLDER' not found."
        fi
        echo "--- Current Environment ---"
        cat .env
        break
    else
        echo "Invalid selection."
    fi
done
