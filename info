#!/bin/bash
if [[ ! -f .env ]]; then
    echo "Error: .env file not found."
    echo "Run ./link to create or link one."
    exit 1
fi

source .env
source .functions.sh

if [[ "$1" == "help" ]]; then
    echo "Usage: $0 [all|ports|list|<project_env>]"
    echo "  all:   Show running status of all projects"
    echo "  list:  List all available environment files in envs/"
    echo "  ports: Show all used ports"
    exit 0
fi

if [[ "$1" == 'list' ]]; then
    echo "Available projects in envs/:"
    ls envs/
    exit 0
fi

if [[ "$1" == 'all' ]]; then
    ./all
    exit 0
fi

if [[ "$1" == 'ports' ]]; then
    ./ports
    exit 0
fi

# Use specified env file or current .env
ENVFILE=".env"
if [[ -n "$1" ]]; then
    if [[ -f "envs/$1" ]]; then
        ENVFILE="envs/$1"
    else
        echo "Warning: envs/$1 not found, using current .env"
    fi
fi

echo "--- Configuration Info: $ENVFILE ---"

if [[ "$DEFAULT" == "random" ]]; then
    # Dynamically determine APP_URL if random port is used
    OUTPUT=$(docker-compose -p "${PROJECT}" ps 2>/dev/null)
    PORT=$(echo "$OUTPUT" | grep "${PROJECT}-web-1" | sed -r 's/.+0.0.0.0:([[:digit:]]+)->80.+/\1/g')
    
    if [[ -n "$PORT" ]]; then
        sed -E "/^#/d; s|^APP_URL=(.+):random|APP_URL=\1:${PORT}|g" "$ENVFILE"
    else
        sed -E "/^#/d" "$ENVFILE"
    fi
else
    sed -E "/^#/d" "$ENVFILE"
fi
