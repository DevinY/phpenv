#!/bin/bash
source .functions.sh

# Store current link to restore later
CURRENT_LINK=$(readlink .env)

# Find all env files in envs/
ENV_FILES=$(find envs -maxdepth 1 -type f -not -path 'envs/.*')

for FILE in $ENV_FILES; do
    PROJECT_NAME=$(grep -Ei "^PROJECT=" "$FILE" | cut -d= -f2 | tr -d '\r')
    
    if [[ "$FILE" == "$CURRENT_LINK" ]]; then
        echo "Project: * ${PROJECT_NAME} (current)"
    else
        echo "Project: ${PROJECT_NAME}"
    fi

    SUBCMD=${1:-ps}
    
    # Check for duplicate project names across env files
    MATCH_COUNT=$(grep -c "PROJECT=${PROJECT_NAME}$" envs/*)
    if [[ $MATCH_COUNT -gt 1 ]]; then
        echo "Error: Duplicate project name '${PROJECT_NAME}' found in envs/."
        grep "PROJECT=${PROJECT_NAME}$" envs/*
        continue
    fi

    echo "Action: ${SUBCMD} for Project: ${PROJECT_NAME} (${FILE})"
    ln -sf "$FILE" .env
    ./console "${SUBCMD}"
    echo -e "-------------------------------------------\n"
done

# Restore original link
if [[ -n "$CURRENT_LINK" ]]; then
    ln -sf "$CURRENT_LINK" .env
fi
